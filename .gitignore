# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# local agent / IDE
.claude/

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# built text files
build_*.txt
tsc_errors*.txt

# Python bytecode (auto-created when you run .py scripts — never commit)
__pycache__/
*.py[cod]
*$py.class
.Python

# modal-rag (RAG service deployed to Modal; local .env optional)
modal-rag/.env
modal-rag/.venv/

# supabase local temp state
supabase/.temp/

# local-only data caches (orphan SQLite, etc. — keep on disk, never commit)
/data/local-cache/

# transient debug dumps (moved here from project root)
/docs/dev-notes/.tsc-check.txt
