# RAG Supabase project (separate from the main app Supabase)
RAG_SUPABASE_URL=https://your-rag-project.supabase.co
RAG_SUPABASE_ANON_KEY=eyJhbGciOi...

# Embedding mode:
#   "local" = load BAAI/bge-m3 in-process (requires ~2.2GB RAM)
#   Any URL = POST to an external embedding API (e.g., Modal endpoint)
EMBED_MODE=local

# Server config
HOST=0.0.0.0
PORT=8100
CORS_ORIGINS=["http://localhost:3000"]
