# Used by the RAG service (Modal or local uvicorn). Configure the same keys in Modal Secret "custom-secret".

# RAG Supabase project (separate from the main app Supabase)
RAG_SUPABASE_URL=https://your-rag-project.supabase.co
RAG_SUPABASE_ANON_KEY=eyJhbGciOi...

# Embedding mode:
#   "local" = load BAAI/bge-m3 in-process (requires ~2.2GB RAM)
#   Any URL = POST to an external embedding API (e.g., Modal endpoint)
EMBED_MODE=local

# Optional: folder with a saved BGE-M3 snapshot (config.json, model.safetensors, tokenizer…).
# Example (Windows): C:/Users/you/Downloads/TestBee-Rag-Template/data/models/bge-m3
# Leave unset to use Hugging Face BAAI/bge-m3 (download on first run).
# EMBED_LOCAL_MODEL_PATH=

# Server config
HOST=0.0.0.0
PORT=8100
CORS_ORIGINS=["http://localhost:3000"]
